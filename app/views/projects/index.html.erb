<% content_for :title, "Proyectos" %>

<div class="page-header">
  <h1>Proyectos</h1>
  <%= link_to "Nuevo proyecto", new_project_path, class: "btn btn-primary" %>
</div>

<div class="filter-tabs">
  <%= link_to "Todos", projects_path, class: class_names("filter-tab", active: @status_filter.nil?) %>
  <% Project.statuses.keys.each do |status| %>
    <%= link_to t("project_statuses.#{status}"), projects_path(status: status),
                class: class_names("filter-tab", active: @status_filter == status) %>
  <% end %>
</div>

<% if @projects.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>Título</th>
        <th>Cliente</th>
        <th>Estado</th>
        <th>Progreso</th>
        <th class="actions"></th>
      </tr>
    </thead>
    <tbody>
      <% @projects.each do |project| %>
        <tr>
          <td><%= link_to project.title, project %></td>
          <td><%= link_to project.client.name, project.client %></td>
          <td><%= status_badge(project) %></td>
          <td><%= project.progress %>%</td>
          <td class="actions">
            <%= link_to "Ver", project %>
            <%= link_to "Editar", edit_project_path(project) %>
            <%= button_to "Eliminar", project, method: :delete, class: "btn btn-danger btn-sm",
                          data: { turbo_confirm: "¿Eliminar el proyecto #{project.title}? Esta acción no se puede deshacer." } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty-state">
    <% if @status_filter %>
      No hay proyectos con estado "<%= t("project_statuses.#{@status_filter}") %>".
    <% else %>
      Todavía no hay proyectos cargados.
    <% end %>
  </p>
<% end %>
