<% content_for :title, "Clientes" %>

<div class="page-header">
  <h1>Clientes</h1>
  <%= link_to "Nuevo cliente", new_client_path, class: "btn btn-primary" %>
</div>

<% if @clients.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Email</th>
        <th>Proyectos</th>
        <th class="actions"></th>
      </tr>
    </thead>
    <tbody>
      <% @clients.each do |client| %>
        <tr>
          <td><%= link_to client.name, client %></td>
          <td><%= client.email %></td>
          <td><%= client.projects.size %></td>
          <td class="actions">
            <%= link_to "Ver", client %>
            <%= link_to "Editar", edit_client_path(client) %>
            <%= button_to "Eliminar", client, method: :delete, class: "btn btn-danger btn-sm",
                          data: { turbo_confirm: "¿Eliminar a #{client.name}? Esta acción no se puede deshacer." } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty-state">Todavía no hay clientes cargados.</p>
<% end %>
